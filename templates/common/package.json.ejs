{
  "name": "<%= projectName %>",
  "version": "1.0.0",
  "description": "",
  "type": "module",<% if (useTypeScript) { %>
  "main": "dist/server.js",<% } else { %>
  "main": "src/server.js",<% } %>
  "scripts": {
    "dev": "<% if (useTypeScript) { %>tsx watch src/server.ts<% } else { %>node --watch src/server.js<% } %>",
    "build": "<% if (useTypeScript) { %>tsc<% } else { %>echo 'No build step required'<% } %>",
    "start": "<% if (useTypeScript) { %>node dist/server.js<% } else { %>node src/server.js<% } %>"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"<% if (useMongoDb) { %>,
    "mongoose": "^8.14.2"<% } %><% if (useRedis && redisClient === 'ioredis') { %>,
    "ioredis": "^5.6.1"<% } %><% if (useRedis && redisClient === 'redis') { %>,
    "redis": "^4.7.0"<% } %>
  },
  "devDependencies": {<% if (useTypeScript) { %>
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"<% } else { %>
    "@types/node": "^22.15.0"<% } %>
  }
}
